<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tvMainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FUEL &amp;\nMETABOLICS"
                    android:textColor="@android:color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        tools:text="Oct 24" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clHydration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_chart_surface"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvHydrationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HYDRATION"
                    android:textColor="@color/neon_yellow"
                    android:textSize="20sp"
                    android:textStyle="bold|italic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvWaterCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/tvWaterMax"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvWaterMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="/8"
                    android:textColor="@color/text_gray"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/tvWaterCount"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GLASSES"
                    android:textColor="@color/text_gray"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvWaterMax" />

                <TextView
                    android:id="@+id/tvHydrationSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optimal flow for muscle recovery"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHydrationTitle" />

                <ProgressBar
                    android:id="@+id/pbWater"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="20dp"
                    android:max="8"
                    android:progress="6"
                    android:progressDrawable="@drawable/bg_rounded_bar_active"
                    app:layout_constraintTop_toBottomOf="@id/tvHydrationSub" />

                <LinearLayout
                    android:id="@+id/llWaterDrops"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/pbWater">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:src="@drawable/ic_water" app:tint="@color/neon_yellow" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="8dp" android:layout_weight="1" android:alpha="0.2" android:src="@drawable/ic_water" app:tint="@color/text_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_weight="1" android:alpha="0.2" android:src="@drawable/ic_water" app:tint="@color/text_gray" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnLogWater"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/neon_yellow"
                    android:text="LOG 250ML"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/ic_add"
                    app:iconTint="#000000"
                    app:iconGravity="textStart"
                    app:layout_constraintTop_toBottomOf="@id/llWaterDrops" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAILY PROGRESS"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/tvDailyKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="kcal"
                        android:textColor="@color/neon_yellow"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbDailyCalories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="@color/neon_yellow"
                    android:progressBackgroundTint="@color/text_gray" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvDailyPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% of daily goal"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvDailyGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2,500 goal ✎"
                        android:textColor="@color/neon_yellow"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Logs"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvViewAllFood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW ALL"
                    android:textColor="@color/neon_yellow"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"/>

            <LinearLayout
                android:id="@+id/btnAddFood"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/neon_yellow" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="ADD NEW FOOD"
                    android:textColor="@color/neon_yellow"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>