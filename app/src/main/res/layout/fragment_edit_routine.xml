<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStateEdit"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ImageButton android:id="@+id/ibEditBack" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginStart="16dp" android:layout_marginTop="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" app:tint="@color/neon_yellow" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Edit Routine" android:textColor="@color/neon_yellow" android:textSize="18sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/ibEditBack" app:layout_constraintStart_toEndOf="@id/ibEditBack" app:layout_constraintTop_toTopOf="@id/ibEditBack" />

        <TextView android:id="@+id/tvSaveRoutine" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="20dp" android:background="@drawable/bg_pill_dark" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:text="SAVE" android:textColor="@color/neon_yellow" android:textSize="12sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/ibEditBack" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/ibEditBack" />

        <TextView android:id="@+id/tvEditSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginTop="24dp" android:text="CURRENT ROUTINE" android:textColor="@color/text_gray" android:textSize="10sp" android:letterSpacing="0.1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/ibEditBack" />
        <EditText android:id="@+id/tvEditRoutineName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:textColor="@android:color/white" android:textSize="28sp" android:textStyle="bold|italic" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvEditSubtitle" tools:text="HYPERTROPHY V.2\nFOCUS" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditRoutineName">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEditExercises"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="3" />

                <LinearLayout
                    android:id="@+id/btnAddNewExercise"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_dashed_border"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_pill_yellow" android:padding="8dp" android:src="@drawable/ic_add" app:tint="#000" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="ADD NEW EXERCISE" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStateSelect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:visibility="gone"> <ImageButton android:id="@+id/ibSelectBack" android:layout_width="48dp" android:layout_height="48dp" android:layout_marginStart="16dp" android:layout_marginTop="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_back_arrow" app:tint="@color/neon_yellow" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SELECT NEW EXERCISES" android:textColor="@color/neon_yellow" android:textSize="16sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="@id/ibSelectBack" app:layout_constraintStart_toEndOf="@id/ibSelectBack" app:layout_constraintTop_toTopOf="@id/ibSelectBack" />

        <EditText android:id="@+id/etSearchExercise" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginHorizontal="20dp" android:layout_marginTop="24dp" android:background="@drawable/bg_pill_dark" android:drawableStart="@drawable/ic_search" android:drawablePadding="12dp" android:drawableTint="@color/text_gray" android:hint="Search exercises..." android:paddingHorizontal="16dp" android:textColor="@android:color/white" android:textColorHint="@color/text_gray" app:layout_constraintTop_toBottomOf="@id/ibSelectBack" />

        <HorizontalScrollView android:id="@+id/svChips" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:clipToPadding="false" android:paddingHorizontal="20dp" android:scrollbars="none" app:layout_constraintTop_toBottomOf="@id/etSearchExercise">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/chipAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:background="@drawable/bg_pill_yellow" android:paddingHorizontal="20dp" android:paddingVertical="8dp" android:text="ALL" android:textColor="#000" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/chipChest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:background="@drawable/bg_pill_dark" android:paddingHorizontal="20dp" android:paddingVertical="8dp" android:text="CHEST" android:textColor="@color/text_gray" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/chipBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:background="@drawable/bg_pill_dark" android:paddingHorizontal="20dp" android:paddingVertical="8dp" android:text="BACK" android:textColor="@color/text_gray" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/chipLegs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_pill_dark" android:paddingHorizontal="20dp" android:paddingVertical="8dp" android:text="LEGS" android:textColor="@color/text_gray" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView android:id="@+id/tvSelectRecommended" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginTop="24dp" android:text="Recommended" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold|italic" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/svChips" />

        <TextView android:id="@+id/tvSelectCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="20dp" android:text="24 ITEMS" android:textColor="@color/text_gray" android:textSize="10sp" app:layout_constraintBottom_toBottomOf="@id/tvSelectRecommended" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/tvSelectRecommended" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDatabaseExercises"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSelectRecommended" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>