<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ImageButton
        android:id="@+id/ibCloseSession"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/neon_yellow" />

    <TextView
        android:id="@+id/tvHeaderStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WORKOUT IN PROGRESS"
        android:textColor="@color/neon_yellow"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ibCloseSession"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ibCloseSession" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStateActive"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ibCloseSession">

        <ImageView
            android:id="@+id/ivActiveGif"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:layout_constraintHeight_percent="0.45"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/bg_card_dark" />

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/gradient_bottom_up"
            app:layout_constraintBottom_toBottomOf="@id/ivActiveGif" />

        <TextView
            android:id="@+id/tvActiveName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/neon_yellow"
            android:textSize="32sp"
            android:textStyle="bold|italic"
            app:layout_constraintBottom_toBottomOf="@id/ivActiveGif"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="BARBELL SQUATS" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT EXERCISE"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toTopOf="@id/tvActiveName"
            app:layout_constraintStart_toStartOf="@id/tvActiveName" />

        <LinearLayout
            android:id="@+id/llActiveInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_pill_dark"
            android:orientation="horizontal"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/ivActiveGif">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROGRESS" android:textColor="@color/text_gray" android:textSize="10sp" />
                <TextView android:id="@+id/tvActiveSetInfo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" tools:text="Set 1 of 4" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEXT UP" android:textColor="@color/text_gray" android:textSize="10sp" />
                <TextView android:id="@+id/tvActiveNextUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/holo_orange_light" android:textSize="16sp" android:textStyle="bold" tools:text="Bench Press" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvActiveTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/neon_yellow"
            android:textSize="80sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/llActiveControls"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llActiveInfo"
            tools:text="00:45" />

        <LinearLayout
            android:id="@+id/llActiveControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton android:id="@+id/btnActivePrev" android:layout_width="64dp" android:layout_height="64dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_prev" app:tint="@color/text_gray" />
            <ImageButton android:id="@+id/btnActivePause" android:layout_width="80dp" android:layout_height="80dp" android:layout_marginHorizontal="24dp" android:background="@drawable/bg_pill_yellow" android:src="@drawable/ic_pause" app:tint="#000000" />
            <ImageButton android:id="@+id/btnActiveSkip" android:layout_width="64dp" android:layout_height="64dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_skip" app:tint="@color/text_gray" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStateRest"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ibCloseSession">

        <TextView
            android:id="@+id/tvRestPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="PHASE 02 / 05"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REST PERIOD"
            android:textColor="@android:color/white"
            android:textSize="40sp"
            android:textStyle="bold|italic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRestPhase" />

        <TextView
            android:id="@+id/tvRestTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:textColor="@color/neon_yellow"
            android:textSize="80sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRestPhase"
            tools:text="01:30" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clRestUpNext"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_dark"
            app:layout_constraintBottom_toTopOf="@id/btnRestSkip">

            <ImageView android:id="@+id/ivRestNextThumb" android:layout_width="80dp" android:layout_height="80dp" android:layout_marginStart="16dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" tools:src="@drawable/bg_pill_yellow" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="16dp" android:text="UP NEXT" android:textColor="@android:color/holo_orange_light" android:textSize="10sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/ivRestNextThumb" app:layout_constraintTop_toTopOf="parent" />
            <TextView android:id="@+id/tvRestNextName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/ivRestNextThumb" app:layout_constraintTop_toTopOf="parent" tools:text="Bench Press" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRestSkip"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/neon_yellow"
            android:text="SKIP REST ⚡"
            android:textColor="#000000"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clStateSummary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ibCloseSession">

        <TextView
            android:id="@+id/tvSummarySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="120dp"
            android:text="FINISHED STRONG"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Session\nSummary"
            android:textColor="@android:color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSummarySubtitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="40dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/btnSummaryDone">

            <LinearLayout android:layout_width="0dp" android:layout_height="140dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_card_dark" android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL TIME" android:textColor="@color/text_gray" android:textSize="12sp" />
                <TextView android:id="@+id/tvSummaryTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@android:color/white" android:textSize="28sp" android:textStyle="bold" tools:text="52:10" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="140dp" android:layout_weight="1" android:layout_marginStart="8dp" android:background="@drawable/bg_pill_yellow" android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CALORIES" android:textColor="#000000" android:textSize="12sp" />
                <TextView android:id="@+id/tvSummaryKcal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000" android:textSize="36sp" android:textStyle="bold" tools:text="450" />
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSummaryDone"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/neon_yellow"
            android:text="DONE"
            android:textColor="#000000"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>