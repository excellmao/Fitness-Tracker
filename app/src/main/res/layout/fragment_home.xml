<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:clipToPadding="false"
    android:paddingBottom="100dp"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR PROGRESS"
            android:textColor="#B3B3B3"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWeeklyBeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="WEEKLY BEAT"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProgressLabel" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvChartContainer"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvWeeklyBeat">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:weightSum="7">

                <include layout="@layout/item_day_bar" android:id="@+id/barMon" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barTue" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barWed" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barThu" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barFri" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barSat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <include layout="@layout/item_day_bar" android:id="@+id/barSun" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/llQuickActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/cvChartContainer">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_circle_dark"
                    android:padding="20dp"
                    android:src="@drawable/ic_run"
                    app:tint="#D4FF00" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="START\nRUN"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_circle_dark"
                    android:padding="20dp"
                    android:src="@drawable/ic_meal"
                    app:tint="#FF7043" /> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="TRACK\nMEAL"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_circle_dark"
                    android:padding="20dp"
                    android:src="@drawable/ic_water"
                    app:tint="#FFCA28" /> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="LOG\nWATER"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRecommendedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="RECOMMENDED"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llQuickActions" />

        <TextView
            android:id="@+id/tvViewAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIEW ALL"
            android:textColor="#D4FF00"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvRecommendedLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRecommendedLabel" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tvRecommendedLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>